# Discord Bot Configuration
# ========================

# REQUIRED: Discord Bot Token
# Get it from: https://discord.com/developers/applications → Bot → Token
DISCORD_TOKEN=your_bot_token_here

# REQUIRED: Discord Application ID (Client ID)
# Get it from: https://discord.com/developers/applications → General Information → Application ID
DISCORD_CLIENT_ID=your_application_id_here

# Lavalink Configuration (Primary Node)
# =======================================
# The bot automatically discovers additional public Lavalink v4 nodes for redundancy.
# This is your primary/preferred node. If it fails, the bot falls over to others automatically.
#
# Free public node example: lavalink-v4.triniumhost.com:443 (password: free)
# For port 443 always set LAVALINK_SECURE=true

LAVALINK_URL=lavalink-v4.triniumhost.com:443
LAVALINK_PASSWORD=free
LAVALINK_SECURE=true
