# Obligatorio: token del bot de Discord
DISCORD_TOKEN=

# Lavalink (nodo principal). Formato host:puerto
LAVALINK_URL=localhost:2333
LAVALINK_PASSWORD=youshallnotpass
# Forzar WSS (solo si tu nodo lo requiere y no está en 443)
# LAVALINK_SECURE=true

# HTTP healthcheck (GET /ping, /health)
HEALTHCHECK_PORT=3000

# Nivel de log: error | warn | info | debug
LOG_LEVEL=info

# Opcional: registro instantáneo de slash commands en un servidor
# GUILD_ID=
# DISCORD_GUILD_ID=

# Opcional: ID de aplicación si deploy-commands no puede resolverlo
# DISCORD_CLIENT_ID=
